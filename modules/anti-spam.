const cooldowns = new Map();

module.exports = {
    name: "antispam",
    description: "Kiểm tra hệ thống chống quét tự động",
    run: async function(api, event, args) {
        const userId = event.senderID;
        const now = Date.now();
        const COOLDOWN_TIME = 5000; // Mỗi người phải đợi 5 giây mới được dùng lại lệnh

        if (cooldowns.has(userId)) {
            const expirationTime = cooldowns.get(userId) + COOLDOWN_TIME;
            if (now < expirationTime) {
                const timeLeft = ((expirationTime - now) / 1000).toFixed(1);
                return api.sendMessage(`⚠️ Chống spam kích hoạt! Bạn đang thao tác quá nhanh, hãy đợi ${timeLeft} giây nữa.`, event.threadID, event.messageID);
            }
        }

        cooldowns.set(userId, now);
        setTimeout(() => cooldowns.delete(userId), COOLDOWN_TIME);

        return api.sendMessage("🛡️ Hệ thống bảo mật: Hoạt động bình thường.\nCooldowm lệnh hiện tại: 5s/lần.", event.threadID, event.messageID);
    }
};
